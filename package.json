{
  "name": "mission-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Live localhost web dashboard over the Mission Control vault (read-only).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts & vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^4.22.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
